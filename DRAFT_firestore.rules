rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'bfgdht45@gmail.com'; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Users ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'role', 'displayName', 'balance', 'status', 'createdAt']) &&
               data.keys().size() <= 8 &&
               data.uid is string && data.uid == userId &&
               data.email is string && data.email.size() <= 256 &&
               data.role in ['student', 'teacher', 'admin'] &&
               data.displayName is string && data.displayName.size() <= 100 &&
               data.balance is number && data.balance >= 0 &&
               data.status in ['pending', 'approved', 'rejected'] &&
               data.createdAt is string &&
               (!data.keys().hasAny(['photoURL']) || (data.photoURL is string && data.photoURL.size() <= 512));
      }

      allow get: if isSignedIn();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                      incoming().role == 'student' && 
                      incoming().status == 'approved' && 
                      incoming().balance == 0;

      allow update: if (
        (isOwner(userId) && isValidUser(incoming()) && 
         incoming().role == existing().role && 
         incoming().status == existing().status && 
         incoming().balance == existing().balance &&
         incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])) ||
        (isAdmin() && isValidUser(incoming()) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['role', 'status', 'balance']))
      );
    }

    // --- Courses ---
    match /courses/{courseId} {
      function isValidCourse(data) {
        let mandatoryKeys = ['title', 'teacherId', 'teacherName', 'price', 'description', 'thumbnail', 'category', 'studentsCount', 'revenue', 'content', 'status', 'createdAt', 'updatedAt'];
        return data.keys().hasAll(mandatoryKeys) &&
               data.keys().size() == 13 &&
               data.title is string && data.title.size() <= 200 &&
               data.teacherId is string && isValidId(data.teacherId) &&
               data.price is number && data.price >= 0 &&
               data.status in ['pending', 'approved', 'rejected'] &&
               data.content is list && data.content.size() <= 100 &&
               data.updatedAt is string;
      }

      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn() && isValidCourse(incoming()) && 
                      incoming().teacherId == request.auth.uid && 
                      incoming().status == 'pending' &&
                      incoming().studentsCount == 0 &&
                      incoming().revenue == 0;

      allow update: if (
        (isOwner(existing().teacherId) && isValidCourse(incoming()) && 
         incoming().teacherId == existing().teacherId &&
         incoming().status == existing().status &&
         incoming().studentsCount == existing().studentsCount &&
         incoming().revenue == existing().revenue &&
         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'thumbnail', 'category', 'content', 'updatedAt'])) ||
        (isAdmin() && isValidCourse(incoming())) ||
        (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['studentsCount', 'revenue']))
      );

      allow delete: if isAdmin() || isOwner(existing().teacherId);
    }

    // --- Enrollments ---
    match /enrollments/{enrollmentId} {
      function isValidEnrollment(data) {
        return data.keys().hasAll(['userId', 'courseId', 'enrolledAt']) &&
               data.keys().size() == 3 &&
               data.userId == request.auth.uid &&
               isValidId(data.courseId);
      }

      allow read: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidEnrollment(incoming()) &&
                      exists(/databases/$(database)/documents/courses/$(incoming().courseId));
    }
  }
}
